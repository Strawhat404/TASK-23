# Pre-built test runner image with all system dependencies.
# Eliminates runtime apt-get install for deterministic, immutable test environments.
FROM rust:1.88-bookworm

RUN apt-get update -qq \
    && apt-get install -y -qq --no-install-recommends \
       pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
